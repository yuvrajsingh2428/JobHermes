# ============================================================
# JobHermes Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3

# Database
DATABASE_PATH=./data/jobhermes.db

# Reports Output Directory
REPORTS_DIR=./output/reports

# Resume/Cover Letter Output Directory
DOCUMENTS_DIR=./output/documents

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Scheduler (cron expression - default 9AM IST = 3:30AM UTC)
CRON_SCHEDULE=30 3 * * *
TIMEZONE=Asia/Kolkata

# Scraping Configuration
SCRAPE_CONCURRENCY=3
REQUEST_DELAY_MS=1500
MAX_RETRIES=3

# Candidate Profile Path
CANDIDATE_PROFILE_PATH=./config/candidate-profile.json

# Company Targets Config Path
COMPANY_TARGETS_PATH=./config/company-targets.json

# Job Scoring Thresholds
MIN_SCORE_THRESHOLD=60
TOP_JOBS_COUNT=10

# TinyFetch / HTTP Settings
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
REQUEST_TIMEOUT_MS=10000
