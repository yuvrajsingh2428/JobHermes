# EditorConfig — https://editorconfig.org
# Ensures consistent coding style across different editors and IDEs

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.json]
indent_size = 2

[*.ts]
indent_size = 2
quote_type = single

[Makefile]
indent_style = tab
